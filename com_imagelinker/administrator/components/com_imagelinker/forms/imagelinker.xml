<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fieldset name="imagelinker" label="imagelinkerLabel">

        <field
            name="folders"
            type="checkboxes"
            label="COM_IMAGELINKER_FOLDERS_TO_SCAN"
            description="COM_IMAGELINKER_FOLDERS_TO_SCAN_DESC"
            class="inputbox"
            default=""
        >
            <option value="">COM_IMAGELINKER_NO_FOLDERS_AVAILABLE</option>
        </field>

        <field
            name="ignore_case"
            type="checkbox"
            label="COM_IMAGELINKER_IGNORE_CASE"
            description="COM_IMAGELINKER_IGNORE_CASE_DESC"
            value="1"
            checked="1"
        />

        <field
            name="unlinked_images"
            type="list"
            multiple="true"
            label="COM_IMAGELINKER_UNLINKED_IMAGES"
            description="COM_IMAGELINKER_UNLINKED_IMAGES_DESC"
            class="inputbox"
        >
            <option value="">COM_IMAGELINKER_SELECT_UNLINKED_IMAGES</option>
        </field>

        <field name="task" type="hidden" default="" />
        <field name="token" type="hidden" default="1" />

    </fieldset>
</form>